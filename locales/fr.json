{
  "text_-4UgcO": "<span>Facilitation\n</span>",
  "text_-f8xt0": "<span><span>Des offres\n  </span>\n  <span> \n  </span>\n  <span class=\"locale-node-text4\">claires\n  </span>\n  <span>, \n  </span>\n  <br />\n  <span>des tarifs \n  </span>\n  <span class=\"locale-node-text8\">justes\n  </span>\n</span> \n <style>.locale-node-text4 {\n  color: #123293;\n}\n \n.locale-node-text8 {\n  color: #123293;\n}</style>",
  "text_0L37e-": "<span>Pitch decks &amp; presentations\n</span>",
  "text_0TAbxs": "<span><span>Je vous aide à concevoir des produits numériques pensés pour vos utilisateurs\n  </span>\n  <br />\n  <span>: interfaces intuitives, parcours fluides, maquettes testables, design systems…\n  </span>\n  <br />\n  <span>Je travaille en collaboration étroite avec vos équipes produit et tech.\n  </span>\n</span>",
  "text_0cAuH3": "<span><span>On démarre sous 5 jours Pas de process complexes, \n  </span>\n  <span>pas de mails qui traînent. \n  </span>\n  <br />\n  <span>Une organisation fluide pour \n  </span>\n  <span>que votre projet prenne vie rapidement.\n  </span>\n</span>",
  "text_1PZ0Eo": "<span><span>Un site bien référencé sur les moteurs de recherche \n  </span>\n  <span>attire un trafic de qualité. \n  </span>\n  <br />\n  <span>Je m&apos;assure que chaque \n  </span>\n  <span>aspect de votre site est optimisé pour maximiser votre \n  </span>\n  <br />\n  <span>visibilité en ligne.\n  </span>\n</span>",
  "text_2PAlPa": "<span>Identité visuelle\n</span>",
  "text_4AaVIh": "<span><span>Chez Smalt pas de mauvaise surprise : chaque projet est pensé pour s’adapter à votre réalité, vos objectifs et vos moyens. Mes tarifs sont conçus pour offrir un équilibre \n  </span>\n  <span class=\"relevantPlaces-631301.framer.appInterRegular1\">entre accessibilité, qualité et impact.\n  </span>\n  <br class=\"relevantPlaces-631301.framer.appInterRegular1\" />\n  <br class=\"relevantPlaces-631301.framer.appInterRegular1\" />\n  <span class=\"relevantPlaces-631301.framer.appInterRegular1\">Vous payez pour une vraie valeur : de la réflexion stratégique, une exécution soignée, et un accompagnement humain à chaque étape.\n  </span>\n</span>",
  "text_4LaVkH": "<span>Site responsive\n</span>",
  "text_4ZUz5S": "<span><span>Analyse des besoins utilisateurs et \n  </span>\n  <br />\n  <span>des objectifs métier pour poser \n  </span>\n  <br />\n  <span>des bases solides.\n  </span>\n</span>",
  "text_5TQb70": "<span>Tarifs\n</span>",
  "text_5Wu14z": "<span>Intelligence collective\n</span>",
  "text_5cfslF": "<span>Envie de faire équipe ? \n</span>",
  "text_5hlggh": "<span>Atelier présentiel ou à distance\n</span>",
  "text_6-ltJ0": "<span><span>Des sites web \n  </span>\n  <span>épurés, \n  </span>\n  <br />\n  <span>performants\n  </span>\n  <span>, pensés pour \n  </span>\n  <br />\n  <span>convertir.\n  </span>\n</span>",
  "text_7_ScCz": "<span><span class=\"locale-node-text2\">Aujourd’hui, je mets mes compétences au service de \n  </span>\n  <span class=\"locale-node-text3\">projets concrets, utiles et accessibles. \n  </span>\n  <span class=\"locale-node-text4\">J’aime \n  </span>\n  <br />\n  <span class=\"locale-node-text6\">travailler avec celles et ceux qui veulent rendre leur \n  </span>\n  <span>communication plus claire, leur produit plus fluide, leur \n  </span>\n  <br />\n  <span>idée plus tangible.\n  </span>\n</span> \n <style>.locale-node-text2 {\n  color: var(--dl-color-relevant-places-631301.framer.app-black60);\n}\n \n.locale-node-text3 {\n  color: var(--dl-color-relevant-places-631301.framer.app-codgray);\n}\n \n.locale-node-text4 {\n  color: var(--dl-color-relevant-places-631301.framer.app-black60);\n}\n \n.locale-node-text6 {\n  color: var(--dl-color-relevant-places-631301.framer.app-black60);\n}</style>",
  "text_8oG4RO": "<span>Design Sprint\n</span>",
  "text_BVRHzT": "<span>Web\n</span>",
  "text_CaIuk9": "<span><span>Je vous accompagne de l’idée au \n  </span>\n  <br />\n  <span>prototype fonctionnel, en passant \n  </span>\n  <span>par la recherche utilisateur, les \n  </span>\n  <span>wireframes, les maquettes et les \n  </span>\n  <span>tests.\n  </span>\n  <br />\n  <span>Idéal pour les startups et équipes \n  </span>\n  <span>produit en phase de création ou d\n  </span>\n  <span>’évolution.\n  </span>\n</span>",
  "text_Ci52W1": "<span><span class=\"locale-node-text2\">450\n  </span>\n  <span class=\"locale-node-text3\">€\n  </span>\n  <span class=\"locale-node-text4\"> \n  </span>\n</span> \n <style>.locale-node-text2 {\n  font-size: 48px;\n}\n \n.locale-node-text3 {\n  font-size: 20px;\n}\n \n.locale-node-text4 {\n  font-size: 48px;\n}</style>",
  "text_Dfkctw": "<span><span>Restitution claire et actionnable de \n  </span>\n  <br />\n  <span>ce qui a été produit pendant \n  </span>\n  <br />\n  <span>l’atelier.\n  </span>\n</span>",
  "text_Ej0shw": "<span><span class=\"locale-node-text2\">*Quatre niveaux d’offre selon vos besoins : \n  </span>\n  <span class=\"locale-node-text3\">Basic,\n  </span>\n  <span class=\"locale-node-text4\"> \n  </span>\n  <br />\n  <span class=\"locale-node-text6\">Essential, Professional et Advanced.\n  </span>\n</span> \n <style>.locale-node-text2 {\n  font-weight: 400;\n}\n \n.locale-node-text3 {\n  font-weight: 700;\n}\n \n.locale-node-text4 {\n  font-weight: 400;\n}\n \n.locale-node-text6 {\n  font-weight: 700;\n}</style>",
  "text_EoOnzY": "<span><span>Une session pour vous apprendre \n  </span>\n  <br />\n  <span>à gérer votre site en toute \n  </span>\n  <br />\n  <span>autonomie, sans jargon technique.\n  </span>\n</span>",
  "text_FCg2Yr": "<span>Smart\n</span>",
  "text_FobR_d": "<span>Création de site vitrine\n</span>",
  "text_FuNv0O": "<span><span>Chez Smalt, chaque projet est conçu pour répondre à un vrai besoin, pas pour cocher des cases. On\n  </span>\n  <br />\n  <span>crée ensemble des solutions utiles, alignées sur votre vision, et qui parlent vraiment à vos utilisateurs.\n  </span>\n</span>",
  "text_Gnw9nN": "<span>Devis sur-mesure\n</span>",
  "text_HJr341": "<span>Mes services\n</span>",
  "text_HKBHF-": "<span><span>Faire émerger collectivement des \n  </span>\n  <br />\n  <span>pistes réalistes, utiles et alignées \n  </span>\n  <br />\n  <span>sur les objectifs du groupe\n  </span>\n</span>",
  "text_HQ_AFe": "<span>2\n</span>",
  "text_I25FUD": "<span>à partir de \n</span>",
  "text_I3sitU": "<span><span>Un cadrage stratégique pour \n  </span>\n  <br />\n  <span>définir les objectifs, les parties \n  </span>\n  <br />\n  <span>prenantes et le périmètre du projet \n  </span>\n  <br />\n  <span>pour démarrer sur de bonnes \n  </span>\n  <br />\n  <span>bases.\n  </span>\n</span>",
  "text_Iq7mB-": "<span>Product Designer\n</span>",
  "text_Jm-KFn": "<span><span>Une identité visuelle cohérente \n  </span>\n  <br />\n  <span>avec vos valeurs, vos couleurs, \n  </span>\n  <br />\n  <span>vos typographies et vos visuels.\n  </span>\n</span>",
  "text_Jpz2Rf": "<span>Team\n</span>",
  "text_KFP8Fw": "<span>UI UX Design\n</span>",
  "text_KPwMhL": "<span><span>Création sur-mesure de formats \n  </span>\n  <br />\n  <span>collaboratifs adaptés à ton \n  </span>\n  <br />\n  <span>contexte et à tes enjeux.\n  </span>\n</span>",
  "text_K_czwT": "<span><span>Réservez un appel gratuit de 20 minutes\n  </span>\n  <br />\n  <span>Un premier échange pour comprendre votre besoin, \n  </span>\n  <span>clarifier vos enjeux et voir si on avance ensemble. C’est \n  </span>\n  <span>simple, sans engagement.\n  </span>\n</span>",
  "text_Ki3mus": "<span><span>Des balises, métadonnées et \n  </span>\n  <br />\n  <span>bonnes pratiques intégrées pour \n  </span>\n  <br />\n  <span>améliorer votre visibilité sur \n  </span>\n  <br />\n  <span>Google.\n  </span>\n</span>",
  "text_L5DUUB": "<span><span>Smalt, c’est aussi une aventure\n  </span>\n  <br />\n  <span>humaine. Je crois aux collaborations\n  </span>\n  <br />\n  <span>durables, basées sur la confiance, la\n  </span>\n  <br />\n  <span>transparence et l’écoute mutuelle.\n  </span>\n  <br />\n  <span>Que vous soyez développeur·se,\n  </span>\n  <br />\n  <span>consultant·e, agence, coworking ou\n  </span>\n  <br />\n  <span>structure publique : je suis toujours\n  </span>\n  <br />\n  <span>ouverte à créer des synergies.  Envie\n  </span>\n  <br />\n  <span>de monter un projet à deux, de co-\n  </span>\n  <br />\n  <span>construire une offre ou de faire appel\n  </span>\n  <br />\n  <span>à une expertise design ? Parlons-en.\n  </span>\n</span>",
  "text_LKhK-k": "<span>Delivery\n</span>",
  "text_Mgx5tw": "<span>Lancer votre projet\n</span>",
  "text_NQk6PM": "<span>Web Design\n</span>",
  "text_NSHO2k": "<span>SEO friendly\n</span>",
  "text_O2OdVa": "<span><span>Un site clair, responsive et \n  </span>\n  <br />\n  <span>optimisé pour présenter votre \n  </span>\n  <br />\n  <span>activité avec impact.\n  </span>\n</span>",
  "text_OCZGDb": "<span><span>Idéal pour les entrepreneur·es, \n  </span>\n  <br />\n  <span>petites entreprises ou associations \n  </span>\n  <br />\n  <span>qui veulent une présence en ligne \n  </span>\n  <br />\n  <span>efficace et facile à prendre en main.\n  </span>\n</span>",
  "text_PUDQi_": "<span>Design\n</span>",
  "text_QfpFss": "<span><span>Workshops, design sprints, \n  </span>\n  <br />\n  <span>ateliers\n  </span>\n  <span> d’alignement ou \n  </span>\n  <br />\n  <span>d’idéation.\n  </span>\n</span>",
  "text_RGChFT": "<span>Product Design\n</span>",
  "text_RWb2T7": "<span>Studio digital\n</span>",
  "text_Ro0crc": "<span><span>Conception de l’architecture et des \n  </span>\n  <br />\n  <span>flux de navigation pour optimiser \n  </span>\n  <br />\n  <span>l’expérience\n  </span>\n</span>",
  "text_SMm6KM": "<span>Discuter de votre projet\n\n</span>",
  "text_SXPb3I": "<span><span>Une approche \n  </span>\n  <span class=\"locale-node-text3\">agile\n  </span>\n  <span>, simple \n  </span>\n  <br />\n  <span>et \n  </span>\n  <span class=\"locale-node-text7\">humaine\n  </span>\n</span> \n <style>.locale-node-text3 {\n  color: #133293;\n}\n \n.locale-node-text7 {\n  color: #133293;\n}</style>",
  "text_Srta6G": "<span><span>Utilisation d’outils comme le \n  </span>\n  <br />\n  <span>design thinking, le design sprint ou \n  </span>\n  <br />\n  <span>le co-développement selon les \n  </span>\n  <br />\n  <span>besoins.\n  </span>\n</span>",
  "text_SyyoOZ": "<span><span class=\"locale-node-text2\">Après plusieurs années en entreprise et en startup,\n  </span>\n  <span class=\"locale-node-text3\"> j’ai choisi de me lancer seule \n  </span>\n  <span class=\"locale-node-text4\">pour travailler \n  </span>\n  <br />\n  <span class=\"locale-node-text6\">différemment :\n  </span>\n  <span> plus près des gens, plus à l’écoute des vrais besoins.\n  </span>\n</span> \n <style>.locale-node-text2 {\n  color: var(--dl-color-relevant-places-631301.framer.app-black60);\n}\n \n.locale-node-text3 {\n  color: var(--dl-color-relevant-places-631301.framer.app-codgray);\n}\n \n.locale-node-text4 {\n  color: rgba(0, 0, 0, 0.4000000059604645);\n}\n \n.locale-node-text6 {\n  color: rgba(0, 0, 0, 0.4000000059604645);\n}</style>",
  "text_TJ7q-7": "<span><span>380\n  </span>\n  <span class=\"locale-node-text3\">€\n  </span>\n  <span> \n  </span>\n</span> \n <style>.locale-node-text3 {\n  font-size: 20px;\n}</style>",
  "text_TU1OVC": "<span><span>Organisation de sessions de co-\n  </span>\n  <br />\n  <span>conception pour aligner les \n  </span>\n  <br />\n  <span>équipes et générer des idées.\n  </span>\n</span>",
  "text_UGZ8Ty": "<span><span>Réalisation de maquettes \n  </span>\n  <br />\n  <span>cliquables pour tester rapidement \n  </span>\n  <br />\n  <span>les fonctionnalités clés.\n  </span>\n</span>",
  "text_WBInJM": "<span>Facilitation UX \n</span>",
  "text_WcmO00": "<span><span class=\"locale-node-text2\">700\n  </span>\n  <span class=\"locale-node-text3\">€\n  </span>\n</span> \n <style>.locale-node-text2 {\n  font-size: 48px;\n}\n \n.locale-node-text3 {\n  font-size: 20px;\n}</style>",
  "text_XAenCB": "<span>A propos\n</span>",
  "text_XGDre4": "<span><span class=\"locale-node-text2\">Je suis designer indépendante spécialisée\n  </span>\n  <span> en Product Design, facilitation et Web design.\n  </span>\n</span> \n <style>.locale-node-text2 {\n  color: var(--dl-color-relevant-places-631301.framer.app-black60);\n}</style>",
  "text_YgwBbR": "<span>Design\n</span>",
  "text_YzBYQz": "<span>Design Thinking\n</span>",
  "text_ZcnJzn": "<span><span>Recueil de retours concrets pour \n  </span>\n  <br />\n  <span>ajuster le design avant la mise en \n  </span>\n  <br />\n  <span>production.\n  </span>\n</span>",
  "text_aCkwb9": "<span><span>Un site rapide, léger et facile à \n  </span>\n  <br />\n  <span>maintenir, conçu sur un outil no-\n  </span>\n  <br />\n  <span>code selon vos besoins.\n  </span>\n</span>",
  "text_aZXUSx": "<span><span>Vous avez des idées, des projets ou des équipes à aligner ? J’anime des ateliers pour structurer votre\n  </span>\n  <br />\n  <span>vision, clarifier vos priorités et avancer ensemble avec des formats courts, concrets et collaboratifs.\n  </span>\n</span>",
  "text_dCrovD": "<span>Discuter de votre projet\n\n</span>",
