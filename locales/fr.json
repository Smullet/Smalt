  "text_h7j6Va": "<span>Product\n</span>",
  "text_irTP4s": "<span><span class=\"locale-node-text11\">Je conçois et anime des sessions \n  </span>\n  <br class=\"locale-node-text12\" />\n  <span class=\"locale-node-text13\">collaboratives qui font avancer vos \n  </span>\n  <br class=\"locale-node-text14\" />\n  <span class=\"locale-node-text15\">projets, en impliquant vos équipes. \n  </span>\n  <br class=\"locale-node-text16\" />\n  <span class=\"locale-node-text17\">Disponible à la session ou en \n  </span>\n  <br class=\"locale-node-text18\" />\n  <span class=\"locale-node-text19\">accompagnement régulier\n  </span>\n  <span>.\n  </span>\n</span> \n <style>.locale-node-text11 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text12 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text13 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text14 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text15 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text16 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text17 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text18 {\n  color: rgba(25, 24, 24, 0.54);\n}\n \n.locale-node-text19 {\n  color: rgba(25, 24, 24, 0.54);\n}</style>",
  "text_j5bEML": "<span><span class=\"locale-node-text2 relevantPlaces-631301.framer.appSemanticHeading22\">Des solutions digitales qui\n  </span>\n  <span class=\"locale-node-text3 relevantPlaces-631301.framer.appSemanticHeading22\"> \n  </span>\n  <span class=\"locale-node-text4 relevantPlaces-631301.framer.appSemanticHeading22\">vous ressemblent\n  </span>\n  <span class=\"locale-node-text5 relevantPlaces-631301.framer.appSemanticHeading22\">, \n  </span>\n  <br class=\"locale-node-text6 relevantPlaces-631301.framer.appSemanticHeading22\" />\n  <span class=\"locale-node-text7 relevantPlaces-631301.framer.appSemanticHeading22\">et qui \n  </span>\n  <span class=\"locale-node-text8\">fonctionnent\n  </span>\n  <span class=\"relevantPlaces-631301.framer.appSemanticHeading22\">.\n  </span>\n</span> \n <style>.locale-node-text2 {\n  font-size: 48px;\n  font-style: normal;\n  font-family: \"HelveticaNeueCyr-Bold\";\n  letter-spacing: 0em;\n}\n \n.locale-node-text3 {\n  font-size: 48px;\n  font-style: normal;\n  font-family: \"HelveticaNeueCyr-Bold\";\n  letter-spacing: 0em;\n}\n \n.locale-node-text4 {\n  color: #123293;\n  font-size: 48px;\n  font-style: normal;\n  font-family: \"HelveticaNeueCyr-Bold\";\n  letter-spacing: 0em;\n}\n \n.locale-node-text5 {\n  font-size: 48px;\n  font-style: normal;\n  font-family: \"HelveticaNeueCyr-Bold\";\n  letter-spacing: 0em;\n}\n \n.locale-node-text6 {\n  font-size: 48px;\n  font-style: normal;\n  font-family: \"HelveticaNeueCyr-Bold\";\n  letter-spacing: 0em;\n}\n \n.locale-node-text7 {\n  font-size: 48px;\n  font-style: normal;\n  font-family: \"HelveticaNeueCyr-Bold\";\n  letter-spacing: 0em;\n}\n \n.locale-node-text8 {\n  color: #123293;\n}</style>",
  "text_jTwdql": "<span>Appel découverte\n</span>",
