  "text_paANOB": "<span>Discovery\n</span>",
  "text_qJKsdT": "<span><span>Mise en place ou amélioration d’un \n  </span>\n  <br />\n  <span>système de composants pour \n  </span>\n  <br />\n  <span>assurer la cohérence et la \n  </span>\n  <br />\n  <span>scalabilité.\n  </span>\n</span>",
