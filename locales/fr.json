  "text_lVN4LT": "<span><span>Mentions légales, politique de \n  </span>\n  <br />\n  <span>confidentialité et gestion des \n  </span>\n  <br />\n  <span>cookies incluses.\n  </span>\n</span>",
  "text_lz49_D": "<span><span>Conduite dynamique et \n  </span>\n  <br />\n  <span>bienveillante pour faire émerger \n  </span>\n  <br />\n  <span>les idées et favoriser l’intelligence \n  </span>\n  <br />\n  <span>collective.\n  </span>\n</span>",
  "text_m5LjHq": "<span>3\n</span>",
  "text_mUmSmc": "<span><span class=\"locale-node-text2\">Je suis basée à\n  </span>\n  <span> Douai, mobile à Lille, et je travaille aussi très bien à distance.\n  </span>\n</span> \n <style>.locale-node-text2 {\n  color: var(--dl-color-relevant-places-631301.framer.app-black60);\n}</style>",
  "text_nLcThz": "<span><span>Smalt accompagne les TPE, PME, startups et collectivités \n  </span>\n  <span>dans la création de solutions numériques utiles, \n  </span>\n  <br />\n  <span>humaines \n  </span>\n  <span>et adaptées à leurs besoins. \n  </span>\n  <br />\n  <span>De la conception de produits \n  </span>\n  <span>digitaux à la création de sites web en passant par l’animation \n  </span>\n  <span>d’ateliers collaboratifs, \n  </span>\n  <br />\n  <span>nous proposons des services sur-\n  </span>\n  <span>mesure, pensés pour vos utilisateurs et vos réalités terrain.\n  </span>\n</span>",
  "text_o8o1Q0": "<span>/ jour\n</span>",
